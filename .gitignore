/music_controler/frontend/build/
/music_controler/frontend/coverage/

# Ignore other common Node files
/music_controler/frontend/.pnp
/music_controler/frontend/.pnp.js
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

